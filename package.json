{
  "name": "desktop-web-demo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.3",
  "scripts": {
    "dev:web": "turbo dev --filter=@demo/web",
    "dev:desktop": "turbo dev --filter=@demo/desktop",
    "dev:daemon": "turbo dev --filter=@demo/daemon",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "ui:add": "cd packages/ui && npx shadcn@latest add"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "lightningcss"
    ]
  }
}
