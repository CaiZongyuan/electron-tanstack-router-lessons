{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@demo/ui/lib/utils": ["./lib/utils.ts"],
      "@demo/ui/lib/*": ["./lib/*"],
      "@demo/ui/components/ui/*": ["./components/ui/*"],
      "@demo/ui/components/*": ["./components/*"],
      "@demo/ui/hooks/*": ["./hooks/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
